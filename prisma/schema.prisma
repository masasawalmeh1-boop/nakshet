enum UserRole {
  designer
  client
  company
}

enum ProjectStatus {
  pending
  in_progress
  completed
  waiting_approval
}

enum UploadCategory {
  design
  video
  branding
}

enum UploadStatus {
  pending_review
  waiting_client_approval
  approved
}

enum ApprovalStatus {
  pending
  approved
  rejected
}

model User {
  id               Int               @id @default(autoincrement())
  name             String
  email            String            @unique
  password         String
  role             UserRole
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  designerProjects Project[]         @relation("DesignerProjects")
  clientProjects   Project[]         @relation("ClientProjects")

  uploads          Upload[]
  sentMessages     Message[]         @relation("SentMessages")
  participants     ChatParticipant[]
  approvals        Approval[]
  notifications    Notification[]
}

model Project {
  id          Int           @id @default(autoincrement())

.page {
  min-height: 100vh;
  display: grid;
  grid-template-columns: 270px 1fr;
  background: #0b1220;
  color: #e5edf8;
}

.sidebar {
  background: linear-gradient(180deg, #10192c 0%, #0d1526 100%);
  border-right: 1px solid rgba(255, 255, 255, 0.08);
  padding: 24px 18px;
  display: flex;
  flex-direction: column;
  gap: 22px;
}

.brand {
  display: flex;
  align-items: center;
  gap: 12px;
}

.brandLogo {
  width: 44px;
  height: 44px;
  border-radius: 14px;
  display: grid;
  place-items: center;
  background: linear-gradient(135deg, #6ea8fe, #8b5cf6);
  color: white;
  font-size: 20px;
  font-weight: 700;
}

.brand h2 {
  margin: 0;
  font-size: 18px;
}

.brand p {
  margin: 4px 0 0;
  color: #90a3bf;
  font-size: 13px;
}

.nav {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.nav button {
  display: flex;
  align-items: center;
  gap: 10px;
  background: transparent;
  color: #c7d4e9;
  border: none;
  border-radius: 14px;
  padding: 12px 14px;
  cursor: pointer;
  font-size: 15px;
  transition: 0.2s ease;
  width: 100%;
  text-align: left;
}

.nav button:hover,
.activeNav {
  background: rgba(110, 168, 254, 0.14) !important;
  color: #ffffff !important;
}

.sidebarCard {
  margin-top: auto;
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid rgba(255, 255, 255, 0.07);
  border-radius: 18px;
  padding: 16px;
}

.sidebarCard h4 {
  margin: 0 0 8px;
}

.sidebarCard p {
  margin: 0;
  color: #aebcd3;
  line-height: 1.7;
  font-size: 14px;
}

.main {
  padding: 28px;
  background:
    radial-gradient(circle at top right, rgba(120, 119, 198, 0.17), transparent 28%),
    radial-gradient(circle at top left, rgba(59, 130, 246, 0.12), transparent 20%),
    #0b1220;
  min-height: 100vh;
}

.topbar {
  display: flex;
  justify-content: space-between;
  gap: 16px;
  align-items: center;
  margin-bottom: 24px;
}

.topbar h1 {
  margin: 0;
  font-size: 30px;
}

.topbar p {
  margin: 8px 0 0;
  color: #9eb1c9;
}

.topbarRight {
  display: flex;
  align-items: center;
  gap: 12px;
}

.alertBtn {
  width: 44px;
  height: 44px;
  border-radius: 14px;
  border: 1px solid rgba(255, 255, 255, 0.08);
  background: rgba(255, 255, 255, 0.04);
  color: white;
  cursor: pointer;
  display: grid;
  place-items: center;
}

.logoutBtn {
  border: none;
  background: linear-gradient(135deg, #ef4444, #dc2626);
  color: white;
  border-radius: 14px;
  padding: 12px 18px;
  cursor: pointer;
  font-weight: 600;
}

.profileBox {
  display: flex;
  align-items: center;
  gap: 12px;
  background: rgba(255, 255, 255, 0.04);
  border-radius: 18px;
  padding: 10px 14px;
  border: 1px solid rgba(255, 255, 255, 0.08);
}

.profileBox strong,
.profileBox span {
  display: block;
}

.profileBox span {
  color: #97a8bf;
  font-size: 13px;
  margin-top: 2px;
}

.avatar {
  width: 42px;
  height: 42px;
  border-radius: 50%;
  background: linear-gradient(135deg, #7c3aed, #2563eb);
  display: grid;
  place-items: center;
  font-weight: 700;
  color: white;
  flex-shrink: 0;
}

.loading,
.emptyState {
  min-height: 300px;
  display: grid;
  place-items: center;
  color: #a8bbd5;
  font-size: 18px;
}

.statsGrid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16px;
  margin-bottom: 22px;
}

.statCard {
  background: rgba(255, 255, 255, 0.05);
  border-radius: 22px;
  padding: 20px;
  border: 1px solid rgba(255, 255, 255, 0.07);
  display: flex;
  align-items: center;
  gap: 14px;
}

.statIcon {
  width: 46px;
  height: 46px;
  border-radius: 14px;
  display: grid;
  place-items: center;
  background: rgba(110, 168, 254, 0.16);
}

.statCard h3 {
  margin: 0;
  font-size: 24px;
}

.statCard p {
  margin: 6px 0 0;
  color: #9bb0ca;
}

.doubleGrid {
  display: grid;
  grid-template-columns: 1.2fr 1fr;
  gap: 18px;
}

.panel {
  background: rgba(255, 255, 255, 0.05);
  border-radius: 24px;
  border: 1px solid rgba(255, 255, 255, 0.08);
  padding: 20px;
}

.chatSidebar,
.chatPanel {
  background: rgba(255, 255, 255, 0.05);
  border-radius: 24px;
  border: 1px solid rgba(255, 255, 255, 0.08);
  padding: 20px;
  height: 100%;
  overflow: hidden;
}

.panelHead {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16px;
}

.panelHead h3 {
  margin: 0;
}

.chatSidebar .panelHead {
  margin-bottom: 14px;
}

.cardList {
  display: flex;
  flex-direction: column;
  gap: 14px;
}

.infoCard,
.uploadCard {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  background: rgba(13, 22, 38, 0.95);
  border: 1px solid rgba(255, 255, 255, 0.06);
  border-radius: 18px;
  padding: 16px;
}

.uploadInfo {
  min-width: 0;
}

.infoCard h4,
.uploadCard h4,
.projectCard h4 {
  margin: 0 0 6px;
}

.infoCard p,
.uploadCard p,
.projectCard p {
  margin: 0 0 5px;
  color: #b1c2d8;
}

.infoCard span,
.uploadCard span {
  color: #8ea4c1;
  font-size: 13px;
}

.statusBadge {
  background: rgba(34, 197, 94, 0.15);
  color: #7ee7a3;
  padding: 8px 12px;
  border-radius: 999px;
  font-size: 12px;
  white-space: nowrap;
}

.fileLink {
  background: linear-gradient(135deg, #3b82f6, #7c3aed);
  color: white;
  text-decoration: none;
  padding: 10px 14px;
  border-radius: 12px;
  font-size: 14px;
  white-space: nowrap;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.projectGrid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16px;
}

.projectCard {
  background: rgba(13, 22, 38, 0.95);
  border: 1px solid rgba(255, 255, 255, 0.06);
  border-radius: 20px;
  padding: 18px;
  text-decoration: none;
  color: inherit;
  display: block;
  transition: transform 0.18s ease, border-color 0.18s ease, box-shadow 0.18s ease;
}

.projectCard:hover {
  transform: translateY(-2px);
  border-color: rgba(110, 168, 254, 0.35);
  box-shadow: 0 12px 28px rgba(0, 0, 0, 0.2);
}

.projectTop {
  display: flex;
  justify-content: space-between;
  gap: 10px;
  align-items: flex-start;
  margin-bottom: 10px;
}

.projectMeta {
  display: flex;
  gap: 14px;
  margin-top: 12px;
  color: #8ea4c1;
  font-size: 13px;
  flex-wrap: wrap;
}

.projectMeta span {
  display: flex;
  align-items: center;
  gap: 6px;
}

.uploadLayout {
  display: grid;
  grid-template-columns: 420px 1fr;
  gap: 18px;
}

.uploadForm {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.uploadForm input,
.uploadForm select,
.uploadForm textarea {
  background: #0d1626;
  color: #eef4ff;
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: 14px;
  padding: 13px 14px;
  outline: none;
  width: 100%;
}

.uploadForm button {
  background: linear-gradient(135deg, #3b82f6, #8b5cf6);
  border: none;
  color: white;
  border-radius: 14px;
  padding: 13px 14px;
  cursor: pointer;
  font-weight: 600;
}

.formActions {
  display: flex;
  gap: 10px;
}

.cancelBtn {
  border: none;
  background: rgba(255, 255, 255, 0.08) !important;
  color: white;
  border-radius: 14px;
  padding: 13px 14px;
  cursor: pointer;
  font-weight: 600;
}

.uploadActions {
  display: flex;
  align-items: center;
  gap: 8px;
}

.actionBtn,
.deleteBtn {
  width: 40px;
  height: 40px;
  border: none;
  border-radius: 12px;
  display: grid;
  place-items: center;
  cursor: pointer;
  color: white;
}

.actionBtn {
  background: linear-gradient(135deg, #2563eb, #3b82f6);
}

.deleteBtn {
  background: linear-gradient(135deg, #ef4444, #dc2626);
}

.messagesLayout {
  display: grid;
  grid-template-columns: 320px 1fr;
  gap: 18px;
  min-height: 70vh;
  height: 70vh;
}

.newChatBtn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  border: none;
  background: linear-gradient(135deg, #3b82f6, #8b5cf6);
  color: white;
  border-radius: 12px;
  padding: 10px 12px;
  cursor: pointer;
  font-size: 13px;
  font-weight: 600;
}

.searchBox {
  width: 100%;
  display: flex;
  align-items: center;
  gap: 10px;
  background: #0d1626;
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: 14px;
  padding: 12px 14px;
  margin-bottom: 14px;
  box-sizing: border-box;
}

.searchBox svg {
  flex-shrink: 0;
  color: #8ea4c1;
}

.searchBox input {
  flex: 1;
  min-width: 0;
  width: 100%;
  background: transparent;
  border: none;
  outline: none;
  color: #eef4ff;
  font-size: 14px;
  font-family: inherit;
}

.searchBox input::placeholder {
  color: #8ea4c1;
}

.chatList {
  display: flex;
  flex-direction: column;
  gap: 12px;
  overflow-y: auto;
  max-height: calc(70vh - 140px);
  padding-right: 6px;
}

.chatList::-webkit-scrollbar {
  width: 8px;
}

.chatList::-webkit-scrollbar-track {
  background: transparent;
}

.chatList::-webkit-scrollbar-thumb {
  background: rgba(110, 168, 254, 0.22);
  border-radius: 999px;
}

.chatListItem {
  background: linear-gradient(180deg, rgba(18, 30, 52, 0.96), rgba(13, 22, 38, 0.96));
  border: 1px solid rgba(255, 255, 255, 0.07);
  border-radius: 18px;
  color: #e7eef9;
  display: flex;
  flex-direction: column;
  align-items: stretch;
  gap: 0;
  text-align: left;
  padding: 16px;
  cursor: pointer;
  width: 100%;
  transition:
    transform 0.18s ease,
    border-color 0.18s ease,
    background 0.18s ease,
    box-shadow 0.18s ease;
  box-shadow: 0 10px 24px rgba(0, 0, 0, 0.18);
}

.chatListItem:hover {
  transform: translateY(-1px);
  border-color: rgba(110, 168, 254, 0.35);
  background: linear-gradient(180deg, rgba(25, 39, 66, 0.98), rgba(16, 27, 47, 0.98));
}

.chatListItem strong {
  display: block;
  font-size: 15px;
  font-weight: 700;
  color: #f5f8ff;
  margin: 0;
  line-height: 1.3;
}

.chatListItem p {
  margin: 0;
  color: #9eb1cb;
  font-size: 13px;
  line-height: 1.45;
}

.chatListTop {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 10px;
  margin-bottom: 6px;
}

.chatTime {
  font-size: 11px;
  color: #8ea4c1;
  white-space: nowrap;
  flex-shrink: 0;
  margin-top: 2px;
}

.chatProjectName {
  margin: 0 0 6px !important;
  color: #9eb1cb;
  font-size: 13px;
  line-height: 1.4;
}

.chatPreviewText {
  display: block;
  color: #7f95b2;
  font-size: 12px;
  line-height: 1.5;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 100%;
}

.chatActive {
  border-color: rgba(110, 168, 254, 0.75) !important;
  background: linear-gradient(180deg, rgba(34, 57, 96, 0.98), rgba(25, 44, 74, 0.98)) !important;
  box-shadow:
    0 0 0 1px rgba(110, 168, 254, 0.18),
    0 14px 30px rgba(0, 0, 0, 0.24);
}

.noSearchResults {
  background: linear-gradient(180deg, rgba(18, 30, 52, 0.96), rgba(13, 22, 38, 0.96));
  border: 1px dashed rgba(255, 255, 255, 0.08);
  border-radius: 18px;
  padding: 22px 18px;
  color: #9fb1c9;
  text-align: center;
  font-size: 14px;
  line-height: 1.6;
}

.chatPanel {
  display: flex;
  flex-direction: column;
  min-height: 0;
  overflow: hidden;
}

.chatHeader {
  padding-bottom: 14px;
  border-bottom: 1px solid rgba(255, 255, 255, 0.08);
}

.chatHeader h3 {
  margin: 0 0 4px;
}

.chatHeader p {
  margin: 0;
  color: #97abc4;
}

.chatHeaderTop {
  display: flex;
  justify-content: space-between;
  gap: 12px;
  align-items: flex-start;
}

.deleteChatBtn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  border: none;
  background: linear-gradient(135deg, #ef4444, #dc2626);
  color: white;
  border-radius: 12px;
  padding: 10px 12px;
  cursor: pointer;
  font-size: 13px;
  font-weight: 600;
  flex-shrink: 0;
}

.membersRow {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  margin-top: 14px;
  color: #9db1cb;
}

.membersList {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.memberBadge {
  background: rgba(59, 130, 246, 0.12);
  border: 1px solid rgba(110, 168, 254, 0.2);
  color: #dbeafe;
  padding: 8px 10px;
  border-radius: 999px;
  font-size: 12px;
  line-height: 1;
}

.messageArea {
  flex: 1;
  overflow-y: auto;
  display: flex;
  flex-direction: column;
  gap: 12px;
  min-height: 0;
  max-height: 100%;
  padding: 18px 6px 18px 0;
  scroll-behavior: smooth;
}

.messageBubble {
  max-width: 72%;
  border-radius: 18px;
  padding: 14px;
}

.messageBubble strong {
  display: block;
  margin-bottom: 6px;
  font-size: 13px;
}

.messageBubble p {
  margin: 0 0 8px;
  line-height: 1.6;
}

.messageBubble span {
  font-size: 12px;
  color: #9ab0ca;
}

.myMessage {
  align-self: flex-end;
  background: linear-gradient(135deg, #2563eb, #7c3aed);
}

.theirMessage {
  align-self: flex-start;
  background: #0d1626;
  border: 1px solid rgba(255, 255, 255, 0.06);
}

.messageComposer {
  display: flex;
  gap: 12px;
  border-top: 1px solid rgba(255, 255, 255, 0.08);
  padding-top: 14px;
  margin-top: 10px;
}

.messageComposer input {
  flex: 1;
  background: #0d1626;
  color: white;
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: 14px;
  padding: 14px;
  outline: none;
}

.messageComposer button {
  display: flex;
  align-items: center;
  gap: 8px;
  border: none;
  background: linear-gradient(135deg, #3b82f6, #8b5cf6);
  color: white;
  border-radius: 14px;
  padding: 0 18px;
  cursor: pointer;
}

.deadlineBadge {
  background: rgba(245, 158, 11, 0.15);
  color: #f7c66b;
  padding: 8px 12px;
  border-radius: 999px;
  font-size: 12px;
  white-space: nowrap;
}

.activityCard {
  display: flex;
  align-items: flex-start;
  gap: 12px;
  background: rgba(13, 22, 38, 0.95);
  border: 1px solid rgba(255, 255, 255, 0.06);
  border-radius: 18px;
  padding: 16px;
}

.activityCard h4 {
  margin: 0 0 6px;
}

.activityCard p {
  margin: 0 0 6px;
  color: #b1c2d8;
}

.activityCard span {
  color: #8ea4c1;
  font-size: 13px;
}

.activityDot {
  width: 12px;
  height: 12px;
  border-radius: 50%;
  background: linear-gradient(135deg, #3b82f6, #8b5cf6);
  margin-top: 6px;
  flex-shrink: 0;
}

.modalOverlay {
  position: fixed;
  inset: 0;
  background: rgba(5, 10, 20, 0.7);
  display: grid;
  place-items: center;
  z-index: 999;
  padding: 20px;
}

.modalCard {
  width: 100%;
  max-width: 520px;
  background: linear-gradient(180deg, #10192c 0%, #0d1526 100%);
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: 24px;
  padding: 22px;
  box-shadow: 0 18px 45px rgba(0, 0, 0, 0.35);
}

.modalHead {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  margin-bottom: 16px;
}

.modalHead h3 {
  margin: 0;
}

.modalCloseBtn {
  width: 38px;
  height: 38px;
  border-radius: 12px;
  border: none;
  background: rgba(255, 255, 255, 0.08);
  color: white;
  display: grid;
  place-items: center;
  cursor: pointer;
}

.modalBody {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.modalBody input,
.modalBody select {
  background: #0d1626;
  color: #eef4ff;
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: 14px;
  padding: 13px 14px;
  outline: none;
  width: 100%;
}

.participantsBox {
  background: rgba(255, 255, 255, 0.04);
  border: 1px solid rgba(255, 255, 255, 0.07);
  border-radius: 18px;
  padding: 14px;
}

.participantsBox h4 {
  margin: 0 0 12px;
  font-size: 14px;
}

.participantsList {
  display: flex;
  flex-direction: column;
  gap: 10px;
  max-height: 220px;
  overflow-y: auto;
  padding-right: 4px;
}

.participantItem {
  display: flex;
  align-items: flex-start;
  gap: 12px;
  background: rgba(13, 22, 38, 0.9);
  border: 1px solid rgba(255, 255, 255, 0.06);
  border-radius: 14px;
  padding: 12px;
  cursor: pointer;
}

.participantItem input {
  width: auto;
  margin-top: 4px;
}

.participantItem strong {
  display: block;
  margin-bottom: 4px;
  font-size: 14px;
}

.participantItem span {
  display: block;
  color: #9bb0ca;
  font-size: 12px;
  line-height: 1.5;
}

.participantsLoading {
  color: #9fb1c9;
  font-size: 14px;
  text-align: center;
  padding: 10px 0;
}

.modalActions {
  display: flex;
  justify-content: flex-end;
  gap: 10px;
  margin-top: 18px;
}

.modalCancelBtn {
  border: none;
  background: rgba(255, 255, 255, 0.08);
  color: white;
  border-radius: 14px;
  padding: 12px 16px;
  cursor: pointer;
  font-weight: 600;
}

.modalCreateBtn {
  border: none;
  background: linear-gradient(135deg, #3b82f6, #8b5cf6);
  color: white;
  border-radius: 14px;
  padding: 12px 16px;
  cursor: pointer;
  font-weight: 600;
}

@media (max-width: 1100px) {
  .page {
    grid-template-columns: 1fr;
  }

  .sidebar {
    border-right: none;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .statsGrid,
  .doubleGrid,
  .uploadLayout,
  .messagesLayout,
  .projectGrid {
    grid-template-columns: 1fr;
  }

  .topbar {
    flex-direction: column;
    align-items: flex-start;
  }

  .messagesLayout {
    height: auto;
  }

  .chatList {
    max-height: 260px;
  }

  .formActions,
  .modalActions {
    flex-direction: column;
  }

  .chatHeaderTop {
    flex-direction: column;
    align-items: flex-start;
  }

  .deleteChatBtn {
    width: 100%;
    justify-content: center;
  }
}